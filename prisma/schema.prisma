generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Item {
  id         String   @id @unique
  branch     String
  status     String
  points     Int
  board      String
  startedAt  String
  finishedAt String
  createdAt  DateTime @default(now())
}

